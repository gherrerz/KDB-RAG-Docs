# Gemini profile
LLM_PROVIDER=gemini

# Optional global override for embedding model.
# If set, this value has precedence over GEMINI_EMBEDDING_MODEL.
LLM_EMBEDDING=

GEMINI_API_KEY=
GEMINI_ANSWER_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Optional integrations
USE_NEO4J=true
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

USE_RQ=false
REDIS_URL=redis://localhost:6379/0
