# OpenAI profile
LLM_PROVIDER=openai

# Optional global override for embedding model.
# If set, this value has precedence over OPENAI_EMBEDDING_MODEL.
LLM_EMBEDDING=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ANSWER_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional integrations
USE_CHROMA=true
CHROMA_PERSIST_DIR=storage/chromadb
CHROMA_COLLECTION=coderag_chunks

USE_NEO4J=true
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

USE_RQ=false
REDIS_URL=redis://localhost:6379/0
