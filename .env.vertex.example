# Vertex AI profile
LLM_PROVIDER=vertex

# Compatibility note: vertex_ai is also accepted.

# Optional global override for embedding model.
# If set, this value has precedence over VERTEX_EMBEDDING_MODEL.
LLM_EMBEDDING=

VERTEX_AI_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_ANSWER_MODEL=gemini-2.0-flash
VERTEX_EMBEDDING_MODEL=text-embedding-005

# Optional integrations
USE_CHROMA=true
CHROMA_PERSIST_DIR=storage/chromadb
CHROMA_COLLECTION=coderag_chunks

USE_NEO4J=true
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

USE_RQ=false
REDIS_URL=redis://localhost:6379/0
