# Vertex AI profile
LLM_PROVIDER=vertex

# Compatibility note: vertex_ai is also accepted.

# Optional global override for embedding model.
# If set, this value has precedence over VERTEX_EMBEDDING_MODEL.
LLM_EMBEDDING=

# Service account JSON encoded in base64 (single line).
# Optional local helper for tests/implementation:
# PowerShell -> $env:VERTEX_SERVICE_ACCOUNT_JSON_B64 = (Get-Content gcp_credentials_vertex.base64.txt -Raw)
VERTEX_PROJECT_ID=
# App decodes this at startup and keeps the JSON available in runtime.
VERTEX_SERVICE_ACCOUNT_JSON_B64=
VERTEX_LOCATION=us-central1
VERTEX_AUTH_TOKEN_URL=https://oauth2.googleapis.com/token
VERTEX_API_BASE_URL=aiplatform.googleapis.com
VERTEX_ANSWER_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_LABEL_SERVICE=webspec-coipo
VERTEX_LABEL_SERVICE_ACCOUNT=qa-anthos
# Fallback only: model_name label is resolved dynamically from
# VERTEX_ANSWER_MODEL or effective embedding model per operation.
VERTEX_LABEL_MODEL_NAME=gemini-2.5-flash
VERTEX_LABEL_USE_CASE_ID=tbd

# Optional integrations
USE_CHROMA=true
CHROMA_PERSIST_DIR=storage/chromadb
CHROMA_COLLECTION=coderag_chunks

USE_NEO4J=true
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

USE_RQ=false
REDIS_URL=redis://localhost:6379/0
