# API and provider placeholders
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ANSWER_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_ANSWER_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
LLM_PROVIDER=openai
LLM_EMBEDDING=
VERTEX_SERVICE_ACCOUNT_JSON=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=
VERTEX_ANSWER_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_LABEL_SERVICE=webspec-coipo
VERTEX_LABEL_SERVICE_ACCOUNT=qa-anthos
# Fallback only: model_name label is resolved dynamically from
# VERTEX_ANSWER_MODEL or effective embedding model per operation.
VERTEX_LABEL_MODEL_NAME=gemini-2.0-flash-001
VERTEX_LABEL_USE_CASE_ID=tbd
USE_NEO4J=true
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
USE_CHROMA=true
CHROMA_PERSIST_DIR=storage/chromadb
CHROMA_COLLECTION=coderag_chunks
USE_RQ=false
REDIS_URL=redis://localhost:6379/0
RQ_INGEST_JOB_TIMEOUT_SEC=900
