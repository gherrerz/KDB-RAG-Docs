GRAPH_HOPS=2
QUERY_MAX_SECONDS=55
OPENAI_TIMEOUT_SECONDS=20
UI_REQUEST_TIMEOUT_SECONDS=90
INVENTORY_PAGE_SIZE=80
INVENTORY_MAX_PAGE_SIZE=300
INVENTORY_ALIAS_LIMIT=8
INVENTORY_ENTITY_LIMIT=500
